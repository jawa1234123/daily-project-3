<!DOCTYPE html>
<html>
<head>

<title>Tambah Alumni</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f5f5f5;
font-family:Arial;
}

.navbar{
background:#A51C30;
}

.navbar-brand{
color:white;
font-weight:bold;
}

.card{
border:none;
box-shadow:0 4px 10px rgba(0,0,0,0.15);
border-radius:10px;
}

.btn-harvard{
background:#A51C30;
color:white;
}

.btn-harvard:hover{
background:#7c1424;
color:white;
}

</style>

</head>

<body>

<nav class="navbar navbar-dark">

<div class="container">

<a class="navbar-brand">Tracer Alumni System</a>

<a class="btn btn-light" href="/dashboard">Dashboard</a>

</div>

</nav>

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card p-4">

<h3 class="text-center mb-4">Tambah Data Alumni</h3>

<form method="POST">

<div class="mb-3">

<label class="form-label">Nama Alumni</label>

<input class="form-control" name="nama" required>

</div>

<div class="mb-3">

<label class="form-label">Jurusan</label>

<input class="form-control" name="jurusan" required>

</div>

<div class="mb-3">

<label class="form-label">Tahun Lulus</label>

<input class="form-control" name="tahun" required>

</div>

<div class="mb-3">

<label class="form-label">Pekerjaan</label>

<input class="form-control" name="pekerjaan">

</div>

<div class="mb-3">

<label class="form-label">Perusahaan</label>

<input class="form-control" name="perusahaan">

</div>

<div class="mb-3">

<label class="form-label">Status Alumni</label>

<select class="form-control" name="status">

<option>Bekerja</option>
<option>Studi Lanjut</option>
<option>Wirausaha</option>

</select>

</div>

<button class="btn btn-harvard w-100">Simpan Data</button>

</form>

</div>

</div>

</div>

</div>

</body>
</html>