<!DOCTYPE html>
<html>
<head>

<title>Laporan Tracer Alumni</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
background:#f5f5f5;
font-family:Arial;
}

.navbar{
background:#A51C30;
}

.navbar-brand{
color:white;
font-weight:bold;
}

.hero{
background:#A51C30;
color:white;
padding:40px;
text-align:center;
}

.card{
border:none;
box-shadow:0 4px 10px rgba(0,0,0,0.15);
border-radius:10px;
}

</style>

</head>

<body>

<nav class="navbar navbar-dark">

<div class="container">

<a class="navbar-brand">Tracer Alumni System</a>

<a class="btn btn-light" href="/dashboard">Dashboard</a>

</div>

</nav>

<div class="hero">

<h1>Laporan Tracer Alumni</h1>

<p>Statistik Alumni Kampus</p>

</div>

<div class="container mt-5">

<div class="row text-center">

<div class="col-md-4">

<div class="card p-4">

<h4>Bekerja</h4>

<h2><%= bekerja %></h2>

</div>

</div>

<div class="col-md-4">

<div class="card p-4">

<h4>Studi Lanjut</h4>

<h2><%= studi %></h2>

</div>

</div>

<div class="col-md-4">

<div class="card p-4">

<h4>Wirausaha</h4>

<h2><%= usaha %></h2>

</div>

</div>

</div>

<hr>

<h4 class="text-center mt-5">Grafik Tracer Alumni</h4>

<canvas id="chart"></canvas>

</div>

<script>

const ctx=document.getElementById("chart")

new Chart(ctx,{
type:"pie",
data:{
labels:["Bekerja","Studi Lanjut","Wirausaha"],
datasets:[{
data:[<%= bekerja %>,<%= studi %>,<%= usaha %>],
backgroundColor:[
"#A51C30",
"#007BFF",
"#28A745"
]
}]
}
})

</script>

</body>
</html>