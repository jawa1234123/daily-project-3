<!DOCTYPE html>
<html>
<head>

<title>Dashboard Tracer Alumni</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

.navbar{
background:#a51c30;
}

.hero{
background:#a51c30;
color:white;
padding:40px;
text-align:center;
}

.card{
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<nav class="navbar navbar-dark">

<div class="container">

<a class="navbar-brand">Tracer Alumni System</a>

<div>

<a class="btn btn-light" href="/tambah">Tambah Alumni</a>

<a class="btn btn-outline-light" href="/laporan">Laporan</a>

<a class="btn btn-outline-light" href="/">Logout</a>

</div>

</div>

</nav>

<div class="hero">

<h1>Dashboard Tracer Alumni</h1>
<p>Sistem Pelacakan Alumni Kampus</p>

</div>

<div class="container mt-4">

<div class="row text-center">

<div class="col-md-4">

<div class="card p-3">

<h4>Bekerja</h4>

<h2><%= bekerja %></h2>

</div>

</div>

<div class="col-md-4">

<div class="card p-3">

<h4>Studi Lanjut</h4>

<h2><%= studi %></h2>

</div>

</div>

<div class="col-md-4">

<div class="card p-3">

<h4>Wirausaha</h4>

<h2><%= usaha %></h2>

</div>

</div>

</div>

<hr>

<h4>Data Alumni</h4>

<table class="table table-striped">

<tr>
<th>Nama</th>
<th>Jurusan</th>
<th>Status</th>
<th>Aksi</th>
</tr>

<% data.forEach(a=>{ %>

<tr>

<td><%= a.nama %></td>
<td><%= a.jurusan %></td>
<td><span class="badge bg-success"><%= a.status %></span></td>

<td>

<a class="btn btn-warning btn-sm" href="/edit/<%= a.id %>">Edit</a>
<a class="btn btn-danger btn-sm" href="/delete/<%= a.id %>">Delete</a>

</td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>